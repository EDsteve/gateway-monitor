TTN_API_KEY=NNSXS.replace-me
TTN_REGION=au1
GATEWAY_IDS=eloc-id-gateway-002,eloc-id-gateway-003
PORT=3030
POLL_INTERVAL_MS=15000

# Firestore project to publish gateway state to. Defaults to eloc-b1e63.
FIREBASE_PROJECT_ID=eloc-b1e63

# Firebase service-account credentials. Pick ONE of the three:
#
# 1. Recommended for Portainer / Cloud Run / Docker: paste the full
#    service-account JSON as a single-line env var.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"eloc-b1e63",...}
#
# 2. Path to a JSON file (Google convention).
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
#
# 3. Or just place the file next to server.js as ./service-account.json
#    (works automatically, no env var needed).

# Optional: write-policy tuning (defaults are 10 minutes for both)
# HEARTBEAT_WRITE_MS=600000
# METADATA_REFRESH_MS=600000
